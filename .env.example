TMDB_API_KEY=your_tmdb_v3_key
PORT=3000

# Google OAuth (console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
# Optional — defaults to http://localhost:3000/api/drive/callback
# Set this when deploying and add the URL to your Google OAuth authorized redirect URIs
# GOOGLE_REDIRECT_URI=https://your-deployed-app.example.com/api/drive/callback

# Descript API (descriptapi.com/v1) — dx_bearer_...:dx_secret_...
DESCRIPT_API_KEY=

